# Flask
SECRET_KEY=change-this-in-production
API_HOST=0.0.0.0
API_PORT=5000

# AI Providers (set at least one)
OPENAI_API_KEY=
MISTRAL_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# AI Models
OPENAI_MODEL=gpt-3.5-turbo
MISTRAL_MODEL=mistral-small
CLAUDE_MODEL=claude-3-5-haiku-latest
GEMINI_MODEL=gemini-1.5-flash

# Multi-provider routing
AI_PRIMARY_PROVIDER=openai
AI_PROVIDER_ORDER=openai,mistral,claude,gemini
AI_REQUEST_TIMEOUT=20

# Token limits
AI_MAX_CONTEXT_MESSAGES=6
AI_MAX_INPUT_CHARS=2800
AI_MAX_SYSTEM_PROMPT_CHARS=450
AI_DEFAULT_MAX_TOKENS=220
AI_SUMMARY_MAX_TOKENS=180
AI_REPLY_MAX_TOKENS=220
AI_ANALYZE_MAX_TOKENS=180

# Optional task-specific provider order
AI_TASK_PROVIDERS_CHAT=
AI_TASK_PROVIDERS_SUMMARY=gemini,claude,mistral,openai
AI_TASK_PROVIDERS_REPLY=claude,openai,mistral,gemini
AI_TASK_PROVIDERS_ANALYZE=openai,gemini,claude,mistral

# Gmail OAuth (choose one approach)
# Approach A: Client ID + Secret
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Approach B: Full OAuth JSON (raw JSON string)
GMAIL_CREDENTIALS_JSON=

# Optional explicit callback URL (usually auto-detected)
# GMAIL_REDIRECT_URI=https://your-domain.vercel.app/api/email/oauth2callback

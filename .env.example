# Flask
SECRET_KEY=change-this-in-production
API_HOST=0.0.0.0
API_PORT=5000

# AI Providers (set at least one)
# OpenRouter - RECOMMENDED (unified API for all models)
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_ENABLED=true
OPENROUTER_PRIMARY_MODEL=openai/gpt-4-turbo
OPENROUTER_MODEL_FALLBACK=openai/gpt-4-turbo,anthropic/claude-3-5-sonnet,mistralai/mistral-large,google/gemini-2.0-pro-exp-02-05

# Legacy individual provider keys (backup)
OPENAI_API_KEY=
MISTRAL_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# AI Models
OPENAI_MODEL=gpt-3.5-turbo
MISTRAL_MODEL=mistral-small
CLAUDE_MODEL=claude-3-5-haiku-latest
GEMINI_MODEL=gemini-1.5-flash

# Multi-provider routing
AI_PRIMARY_PROVIDER=openrouter
AI_PROVIDER_ORDER=openrouter,openai,mistral,claude,gemini
AI_REQUEST_TIMEOUT=20

# Token limits
AI_MAX_CONTEXT_MESSAGES=6
AI_MAX_INPUT_CHARS=2800
AI_MAX_SYSTEM_PROMPT_CHARS=450
AI_DEFAULT_MAX_TOKENS=220
AI_SUMMARY_MAX_TOKENS=180
AI_REPLY_MAX_TOKENS=220
AI_ANALYZE_MAX_TOKENS=180

# Optional task-specific provider order
AI_TASK_PROVIDERS_CHAT=
AI_TASK_PROVIDERS_SUMMARY=openrouter,gemini,claude,mistral,openai
AI_TASK_PROVIDERS_REPLY=openrouter,claude,openai,mistral,gemini
AI_TASK_PROVIDERS_ANALYZE=openrouter,openai,gemini,claude,mistral
# Approach B: Full OAuth JSON (raw JSON string)
GMAIL_CREDENTIALS_JSON=

# Optional explicit callback URL (usually auto-detected)
# GMAIL_REDIRECT_URI=https://your-domain.vercel.app/api/email/oauth2callback
